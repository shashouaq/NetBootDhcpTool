<Window x:Class="NetBootDhcpTool.App.AppDialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" SizeToContent="WidthAndHeight" MinWidth="430" MaxWidth="620" Background="#F7FAFD" FontFamily="Microsoft YaHei UI, Segoe UI">
  <Border Padding="22" BorderBrush="#D0D7DE" BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <DockPanel>
        <Border x:Name="IconBadge" Width="38" Height="38" CornerRadius="19" Background="#E8F2FF" DockPanel.Dock="Left" Margin="0,0,12,0">
          <TextBlock x:Name="IconText" Text="!" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#1769AA"/>
        </Border>
        <TextBlock x:Name="TitleText" FontSize="18" FontWeight="SemiBold" Foreground="#162033" TextWrapping="Wrap"/>
      </DockPanel>
      <TextBlock x:Name="MessageText" Grid.Row="1" Margin="50,12,0,18" FontSize="14" LineHeight="22" Foreground="#2F3B4C" TextWrapping="Wrap"/>
      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="CancelButton" Content="取消 / Cancel" MinWidth="108" Margin="6,0,0,0" Padding="12,6" Click="CancelButton_Click"/>
        <Button x:Name="OkButton" Content="确定 / OK" MinWidth="108" Margin="6,0,0,0" Padding="12,6" FontWeight="SemiBold" Background="#1769AA" Foreground="White" Click="OkButton_Click"/>
      </StackPanel>
    </Grid>
  </Border>
</Window>
