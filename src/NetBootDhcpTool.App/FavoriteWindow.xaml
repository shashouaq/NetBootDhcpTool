<Window x:Class="NetBootDhcpTool.App.FavoriteWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Favorite" Width="720" Height="700" MinWidth="620" MinHeight="540" WindowStartupLocation="CenterOwner" Background="#F6F8FB">
  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="Margin" Value="0,4,12,8"/>
      <Setter Property="MinHeight" Value="28"/>
      <Setter Property="Padding" Value="6,3"/>
    </Style>
    <Style TargetType="Button">
      <Setter Property="MinHeight" Value="30"/>
      <Setter Property="Padding" Value="12,4"/>
      <Setter Property="Margin" Value="4"/>
    </Style>
    <Style x:Key="FieldCellText" TargetType="TextBlock">
      <Setter Property="Padding" Value="4,2"/>
      <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
      <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
    </Style>
  </Window.Resources>
  <DockPanel Margin="16">
    <Border DockPanel.Dock="Top" Padding="0,0,0,10">
      <StackPanel>
        <TextBlock Text="Favorite / 收藏配置" FontSize="20" FontWeight="SemiBold"/>
        <TextBlock Text="Required: name, local IP, mask. Optional fields can be extended below. / 必填：名称、本机 IP、掩码；其它字段可按需扩展。" Foreground="#57606A" Margin="0,4,0,0"/>
      </StackPanel>
    </Border>
    <Border DockPanel.Dock="Bottom" Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="1" Padding="10" Margin="0,10,0,0">
      <DockPanel>
        <TextBlock x:Name="ValidationText" Foreground="#B3261E" DockPanel.Dock="Left"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Content="OK / 确定" Width="96" Click="Ok_Click" Background="#2DA44E" Foreground="White"/>
          <Button Content="Cancel / 取消" Width="96" IsCancel="True"/>
        </StackPanel>
      </DockPanel>
    </Border>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <Border Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="1" Padding="14" Margin="0,0,0,10">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Grid.Column="0">
              <TextBlock Text="Name * / 名称 *"/>
              <TextBox x:Name="NameBox"/>
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="1">
              <TextBlock Text="Device / 设备号"/>
              <TextBox x:Name="DeviceBox"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="0">
              <TextBlock Text="Local IP * / 本机 IP *"/>
              <TextBox x:Name="IpBox"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="1">
              <TextBlock Text="Mask * / 掩码 *"/>
              <TextBox x:Name="MaskBox"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="0">
              <TextBlock Text="Target IP / 对端 IP"/>
              <TextBox x:Name="TargetIpBox"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="1">
              <TextBlock Text="Remark / 备注"/>
              <TextBox x:Name="RemarkBox"/>
            </StackPanel>
            <StackPanel Grid.Row="3" Grid.Column="0">
              <TextBlock Text="SN / 序列号"/>
              <TextBox x:Name="SnBox"/>
            </StackPanel>
            <StackPanel Grid.Row="3" Grid.Column="1"/>
            <StackPanel Grid.Row="4" Grid.Column="0">
              <TextBlock Text="Username / 账号"/>
              <TextBox x:Name="UserBox"/>
            </StackPanel>
            <StackPanel Grid.Row="4" Grid.Column="1">
              <TextBlock Text="Password / 密码"/>
              <TextBox x:Name="PasswordBox"/>
            </StackPanel>
          </Grid>
        </Border>
        <Border Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="1" Padding="14" Margin="0,0,0,10">
          <StackPanel>
            <TextBlock Text="Memory / 文本记忆" FontWeight="SemiBold"/>
            <TextBox x:Name="MemoryBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="110" Margin="0,8,0,0"/>
          </StackPanel>
        </Border>
        <Border Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="1" Padding="14">
          <DockPanel>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
              <TextBlock Text="Custom Fields / 自定义字段" FontWeight="SemiBold"/>
              <Button x:Name="BtnAddField" Content="Add / 新增" Margin="12,0,4,0" Click="AddField_Click"/>
              <Button x:Name="BtnDeleteField" Content="Delete / 删除" Margin="4,0" Click="DeleteField_Click"/>
            </StackPanel>
            <DataGrid x:Name="CustomFieldGrid" AutoGenerateColumns="False" CanUserAddRows="False" CanUserResizeColumns="True" CanUserResizeRows="False" RowHeight="32" MinHeight="130">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Field / 字段" Binding="{Binding Name}" Width="200" MinWidth="120" ElementStyle="{StaticResource FieldCellText}"/>
                <DataGridTextColumn Header="Value / 内容" Binding="{Binding Value}" Width="*" MinWidth="180" ElementStyle="{StaticResource FieldCellText}"/>
              </DataGrid.Columns>
            </DataGrid>
          </DockPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
